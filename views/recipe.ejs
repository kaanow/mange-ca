<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= recipe.title %> — Mange Ça</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <main>
    <article class="recipe-detail">
      <div class="wrap">
        <p class="back"><a href="/">← Recipes</a></p>
        <h1><%= recipe.title %></h1>
        <% if (recipe.summary) { %><div class="summary"><%- formatRecipeText(recipe.summary) %></div><% } %>
        <% if (recipe.ingredients) { %>
        <h2>Ingredients</h2>
        <div class="ingredients"><%- formatRecipeText(recipe.ingredients) %></div>
        <% } %>
        <% if (recipe.instructions) { %>
        <h2>Instructions</h2>
        <div class="instructions"><%- formatRecipeText(recipe.instructions) %></div>
        <% } %>
      </div>
    </article>
  </main>
</body>
</html>
